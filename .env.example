# EAS: eas.json maps build profiles to environments; set this var for production, preview, and development on expo.dev or via:
#   npx eas-cli env:create production --name EXPO_PUBLIC_REVENUECAT_IOS_API_KEY --value 'appl_...' --visibility sensitive
