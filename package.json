    "reset-project": "node ./scripts/reset-project.js",
    "quest-card": "node ./scripts/generate-quest-card.mjs --input ./scripts/quest-card.example.json --out ./assets/share/quest-card.png",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "revenuecat:doctor": "node ./scripts/revenuecat-doctor.mjs",
    "iap:setup": "node ./scripts/revenuecat-doctor.mjs",
    "iap:sync-eas": "node ./scripts/iap-sync-eas.mjs",
    "supabase:deploy:delete-account": "supabase functions deploy delete-account"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
