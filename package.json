    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-modules-core": "~3.0.30",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
