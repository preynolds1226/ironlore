{
  "name": "ironlore",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "eas:init": "eas init",
    "eas:build:ios": "eas build -p ios --profile production",
    "eas:submit:ios": "eas submit -p ios --latest",
    "eas:inject-asc": "node scripts/inject-asc-issuer.mjs",
    "eas:submit:ios:asc": "node scripts/inject-asc-issuer.mjs && eas submit -p ios --profile production --latest --non-interactive",
